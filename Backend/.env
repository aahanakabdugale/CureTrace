# CureTrace Backend — Environment Variables
APP_NAME=CureTrace
APP_ENV=development
DEBUG=True

# Neon Serverless PostgreSQL connection string
# Get from: console.neon.tech → your project → Connect button
# IMPORTANT: scheme must be postgresql+asyncpg:// (NOT postgresql://)
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Secret key for signing QR JWT tokens
SECRET_KEY=change-me-to-a-long-random-secret

# Base URL encoded inside QR codes
QR_BASE_URL=http://localhost:8000
